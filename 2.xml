</div>

<div id="loading-cover" style="display:none;">
    <div id="unity-loading-bar">
        <div id="unity-logo"><img src="https://cdn.jsdelivr.net/gh/docs-g-classroommyflies/real-99-c@main/logo.png" onerror="this.style.display='none'"/></div>
        <div id="unity-progress-bar-empty" style="display:none;">
            <div id="unity-progress-bar-full"></div>
        </div>
        <div class="spinner"></div>
    </div>
</div>

<script>
/* ============================================================
   CONFIG
   ============================================================ */
const BUILD_URL  = "https://cdn.jsdelivr.net/gh/docs-g-classroommyflies/real-99-c@7595aa9/Build";
const DATA_FILE  = "Yandex.data";   /* .br yok */
const WASM_FILE  = "Yandex.wasm";   /* .br yok */
const DATA_PARTS = 9;
const WASM_PARTS = 6;

/* ============================================================
   GLOBALS  — orijinal değişken adları korundu
   ============================================================ */
var cloudSaves      = 'noData';
var paymentsData    = 'none';
var environmentData = 'null';
var playerData      = 'noData';

var player   = null;
var payments = null;
var leaderboard = null;

let myGameInstance  = null;   /* bu oyun myGameInstance kullanıyor */
let initGame        = false;
let nowFullAdOpen   = false;

/* ysdk stub — language:'en' */
var ysdk = {
    environment: {
        i18n:    { lang: 'en', tld: 'com' },
        app:     { id: '0' },
        browser: { lang: 'en' },
        payload: ''
    },
    deviceInfo: {
        type:      'desktop',
        isMobile:  () => false,
        isDesktop: () => true,
        isTablet:  () => false,
        isTV:      () => false,
    },
    screen: { fullscreen: { status: 'off', request: ()=>{}, exit: ()=>{} } },
    adv: {
        showFullscreenAdv:  (o) => {
            o?.callbacks?.onOpen?.();
            setTimeout(() => { o?.callbacks?.onClose?.(true); }, 300);
        },
        showRewardedVideo:  (o) => {
            o?.callbacks?.onOpen?.();
            setTimeout(() => {
                o?.callbacks?.onRewarded?.();
                setTimeout(() => { o?.callbacks?.onClose?.(); }, 200);
            }, 500);
        },
        showBannerAdv:      () => Promise.resolve({ stickyAdvIsShowing: false }),
        hideBannerAdv:      () => Promise.resolve(),
        getBannerAdvStatus: () => Promise.resolve({ stickyAdvIsShowing: false }),
    },
    auth:     { openAuthDialog: () => Promise.resolve() },
    feedback: {
        canReview:     () => Promise.resolve({ value: false, reason: 'YSDK_DISABLED' }),
        requestReview: () => Promise.resolve({ feedbackSent: false }),
    },
    shortcut: {
        canShowPrompt: () => Promise.resolve({ canShow: false }),
        showPrompt:    () => Promise.resolve({ outcome: 'rejected' }),
    },
    getLeaderboards: () => Promise.resolve({
        getLeaderboardDescription: () => Promise.resolve({ default: false, description: { invert_sort_order: false, score_format: { options: { decimal_offset: 0 } }, type: 'numeric' } }),
        getLeaderboardEntries:     () => Promise.resolve({ entries: [] }),
        setLeaderboardScore:       () => {},
    }),
    getPlayer:   () => Promise.resolve({
        getMode:         () => 'lite',
        getName:         () => '',
        getUniqueID:     () => 'unauthorized',
        getPhoto:        () => 'null',
        getPayingStatus: () => 'unknown',
        getData:         () => Promise.resolve({}),
        setData:         () => Promise.resolve(),
    }),
    features: {
        LoadingAPI:  { ready: () => {} },
        GameplayAPI: { start: () => {}, stop: () => {} },
        GamesAPI:    { getAllGames: () => Promise.reject() },
    },
    getPayments: () => Promise.reject(new Error('payments not available')),
    on: () => {},
};

/* ============================================================
   SendMessage helper  — target: 'YandexGame'
   ============================================================ */
function SendYG(method, arg) {
    if (!myGameInstance) return;
    try {
        if (arg !== undefined) myGameInstance.SendMessage('YandexGame', method, arg);
        else                   myGameInstance.SendMessage('YandexGame', method);
    } catch(e) {}
}

/* ============================================================
   GAME FUNCTIONS  — orijinal imzalar korundu
   ============================================================ */
function FocusGame() { window.focus(); canvas.focus(); }

function InitGame() {
    console.log('Init Game Success');
    initGame = true;
    /* FullAdShow init sırasında zaten kapandı, nowFullAdOpen=false */
    if (nowFullAdOpen && myGameInstance) {
        SendYG('OpenFullAd');
    }
}

/* Interstitial — play öncesi çağrılabilir, sıralı delay ile */
function FullAdShow() {
    try {
        if (nowFullAdOpen || !ysdk) return;
        ysdk.adv.showFullscreenAdv({
            callbacks: {
                onOpen: () => {
                    nowFullAdOpen = true;
                    if (initGame) SendYG('OpenFullAd');
                },
                onClose: (wasShown) => {
                    nowFullAdOpen = false;
                    if (initGame) SendYG('CloseFullAd', wasShown ? 'true' : 'false');
                    FocusGame();
                },
                onError: () => {
                    nowFullAdOpen = false;
                    if (initGame) { SendYG('ErrorFullAd'); FocusGame(); }
                }
            }
        });
    } catch(e) { console.error('CRASH FullAd Show:', e.message); }
}

/* Rewarded — sıralı delay ile */
function RewardedShow(id) {
    try {
        ysdk.adv.showRewardedVideo({
            callbacks: {
                onOpen:     () => { SendYG('OpenVideo'); },
                onRewarded: () => { SendYG('RewardVideo', id); },
                onClose:    () => { SendYG('CloseVideo'); FocusGame(); },
                onError:    () => { SendYG('ErrorVideo'); FocusGame(); }
            }
        });
    } catch(e) { console.error('CRASH Rewarded Show:', e.message); }
}

function StickyAdActivity() {}

/* Leaderboard */
function InitLeaderboard() {
    SendYG('InitializedLB');
}
function SetLeaderboardScores() {}
function GetLeaderboardScores(nameLB, maxPlayers) {
    SendYG('LeaderboardEntries', JSON.stringify({
        technoName: nameLB, isDefault: false, isInvertSortOrder: false,
        decimalOffset: 0, type: 'numeric',
        entries: 'no data', ranks: [], photos: [], names: [], scores: [], uniqueIDs: []
    }));
}
function EntriesLB() { return {}; }

/* Review / Shortcut */
function Review() { FocusGame(); }
function PromptShow() { SendYG('OnPromptFail'); FocusGame(); }

/* Cloud */
function SaveCloud() {}
function LoadCloud(sendback) {
    if (sendback) SendYG('SetLoadSaves', 'noData');
    return Promise.resolve('noData');
}

/* Payments */
function GetPayments(sendback) {
    if (sendback) SendYG('PaymentsEntries', 'none');
    return Promise.resolve('none');
}
function BuyPayments(id)    { SendYG('OnPurchaseFailed', id); FocusGame(); }
function ConsumePurchase()  {}
function ConsumePurchases() {}

/* Environment */
function RequestingEnvironmentData(sendback) {
    const j = JSON.stringify({
        language: 'en', domain: 'com', deviceType: 'desktop',
        isMobile: false, isDesktop: true, isTablet: false, isTV: false,
        appID: '0', browserLang: 'en', payload: '',
        promptCanShow: false, reviewCanShow: false,
        platform: '', browser: 'Other'
    });
    if (sendback) SendYG('SetEnvirData', j);
    return Promise.resolve(j);
}

/* Player */
function NotAuthorized() {
    return JSON.stringify({
        playerAuth: 'rejected', playerName: 'unauthorized',
        playerId: 'unauthorized', playerPhoto: 'null'
    });
}
function InitPlayer(sendback) {
    const j = NotAuthorized();
    if (sendback) SendYG('SetInitializationSDK', j);
    return Promise.resolve(j);
}
function OpenAuthDialog() {}

/* ============================================================
   POINTER LOCK FIX
   ============================================================ */
const oRequestPointerLock = Element.prototype.requestPointerLock;
Element.prototype.requestPointerLock = async function(...args) {
    try { (args[0] ||= {}).unadjustedMovement = true; await oRequestPointerLock.apply(this, args); } catch(e) {}
};

/* ============================================================
   SETUP
   ============================================================ */
const container        = document.querySelector("#unity-container");
const canvas           = document.querySelector("#unity-canvas");
const loadingCover     = document.querySelector("#loading-cover");
const progressBarEmpty = document.querySelector("#unity-progress-bar-empty");
const progressBarFull  = document.querySelector("#unity-progress-bar-full");
const spinner          = document.querySelector('.spinner');

canvas.style.background = "url('https://cdn.jsdelivr.net/gh/docs-g-classroommyflies/real-99-c@main/background.png') center / cover";
loadingCover.style.display = "";

if (/iPhone|iPad|iPod|Android/i.test(navigator.userAgent)) {
    container.className = "unity-mobile";
}

document.addEventListener('contextmenu', e => e.preventDefault());
window.addEventListener('pointerdown', () => FocusGame());
window.addEventListener('touchstart',  () => FocusGame());

/* ============================================================
   PART LOADER
   ============================================================ */
function setProgress(pct) {
    spinner.style.display          = "none";
    progressBarEmpty.style.display = "";
    progressBarFull.style.width    = Math.min(pct, 100) + "%";
}

async function fetchParts(filename, count, startPct, endPct) {
    const step   = (endPct - startPct) / count;
    const chunks = [];
    for (let i = 0; i < count; i++) {
        const resp = await fetch(`${BUILD_URL}/${filename}.part${i}`);
        if (!resp.ok) throw new Error(`HTTP ${resp.status} - ${BUILD_URL}/${filename}.part${i}`);
        chunks.push(new Uint8Array(await resp.arrayBuffer()));
        setProgress(Math.round(startPct + step * (i + 1)));
    }
    const total  = chunks.reduce((s, c) => s + c.length, 0);
    const merged = new Uint8Array(total);
    let offset = 0;
    for (const c of chunks) { merged.set(c, offset); offset += c.length; }
    return URL.createObjectURL(new Blob([merged]));
}

/* ============================================================
   MAIN
   ============================================================ */
(async () => {
    try {
        setProgress(2);

        const [dataUrl, wasmUrl] = await Promise.all([
            fetchParts(DATA_FILE, DATA_PARTS, 2,  50),
            fetchParts(WASM_FILE, WASM_PARTS, 50, 88),
        ]);

        setProgress(92);

        /* framework.js ve loader.js .br uzantısız */
        const config = {
            dataUrl:            dataUrl,
            frameworkUrl:       `${BUILD_URL}/Yandex.framework.js`,
            codeUrl:            wasmUrl,
            streamingAssetsUrl: "https://cdn.jsdelivr.net/gh/docs-g-classroommyflies/real-99-c@main/StreamingAssets",
            companyName:        "new",
            productName:        "new",
            productVersion:     "1.0.0",
        };

        /* SDK mesajlarını Unity yüklenmeden önce gönder */
        const _origSendYG = SendYG;

        const loaderScript  = document.createElement("script");
        loaderScript.src    = `${BUILD_URL}/Yandex.loader.js`;
        loaderScript.onload = () => {
            createUnityInstance(canvas, config, (p) => {
                setProgress(Math.round(88 + p * 10));
            }).then((inst) => {
                myGameInstance = inst;
                loadingCover.style.background = "";
                loadingCover.style.display    = "none";

                /* Orijinal init sırası: Cloud → Payments → EnvirData → Player */
                setTimeout(() => {
                    SendYG('SetLoadSaves',        'noData');
                    SendYG('PaymentsEntries',      'none');
                    SendYG('SetEnvirData',         JSON.stringify({
                        language:'en', domain:'com', deviceType:'desktop',
                        isMobile:false, isDesktop:true, isTablet:false, isTV:false,
                        appID:'0', browserLang:'en', payload:'',
                        promptCanShow:false, reviewCanShow:false,
                        platform:'', browser:'Other'
                    }));
                    SendYG('SetInitializationSDK', NotAuthorized());
                }, 500);

                canvas.focus();
            }).catch(e => {
                console.error(e);
                progressBarFull.textContent = "Hata: " + e;
            });
        };
        document.body.appendChild(loaderScript);

    } catch (err) {
        console.error("Yukleme hatasi:", err);
        progressBarFull.style.width = "100%";
        progressBarFull.textContent = "Yukleme hatasi: " + err.message;
    }
})();
</script>
<!-- Sticky Bottom Center Ad (728x90) with Smooth Slide-Out and Reappearance -->
<style>
  /* Container: Bottom center, fixed, with overflow hidden */
  #ad-container {
    position: fixed;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: min(728px, calc(100% - 20px)); /* 728px, 10px margin on mobile */
    height: 90px;
    background: rgba(0, 0, 0, 0.90);
    display: none;
    z-index: 99999;
    border-radius: 0; /* Sharp corners */
    overflow: hidden;
    box-shadow: 0 -2px 12px rgba(0, 0, 0, 0.45);
    box-sizing: border-box;
    transition: transform 0.5s ease-in-out; /* Smooth slide-in/out animation */
  }

  /* Slide-out animation */
  #ad-container.hidden {
    transform: translate(-50%, 100%); /* Slide down out of view */
  }

  #ad-iframe {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 745px; /* Updated width */
    height: 90px; /* Updated height */
    border: 0;
    display: block;
    overflow: hidden;
    pointer-events: auto;
    box-sizing: content-box;
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  
  #ad-iframe::-webkit-scrollbar {
    display: none;
    width: 0;
    height: 0;
  }

  /* Close button with arrow */
  #close-ad {
    position: absolute;
    top: 6px;
    right: 8px;
    background: #ff4d4d;
    color: #fff;
    border: none;
    padding: 5px 9px;
    font-size: 13px;
    border-radius: 4px;
    cursor: not-allowed;
    opacity: 0.72;
    z-index: 100000;
    display: flex;
    align-items: center;
  }
  #close-ad.enabled {
    cursor: pointer;
    opacity: 1;
  }
  #close-ad::before {
    content: '↓'; /* Down arrow for bottom ad */
    margin-right: 4px;
  }

  /* Right mask for scrollbar */
  #ad-right-mask {
    position: absolute;
    top: 0;
    right: 0;
    width: 12px;
    height: 100%;
    pointer-events: none;
    background: linear-gradient(to right, rgba(0, 0, 0, 0), rgba(0, 0, 0, 0.9));
    z-index: 99999;
  }

  /* Mobile adjustments */
  @media (max-width: 440px) {
    #ad-container {
      width: calc(100% - 12px);
      left: 50%;
      transform: translateX(-50%);
      border-radius: 0; /* Sharp corners on mobile */
    }
    #ad-iframe {
      width: 728px;
    }
  }
</style>

<div id="ad-container" aria-hidden="true" role="dialog" aria-label="Advertisement">
  <iframe
    id="ad-iframe"
    src="https://script.google.com/macros/s/AKfycbxLG5DHBe-sIbduDvwQZYJ3oaX_ha7rsvroprCFkQsnpZK_PEdipNia5ghxI_sdXYpv/exec"
    width="768px"
    height="95px"
    scrolling="no"
    frameborder="0"
    sandbox="allow-scripts allow-popups allow-same-origin"
  ></iframe>
  <button id="close-ad" disabled>Close (12)</button>
  <div id="ad-right-mask"></div>
</div>

<script>
  (function () {
    const showDelay = 2000; // 2 seconds delay before first show
    const countdownStart = 12; // 12 seconds countdown
    const reappearDelay = 150000; // 25 seconds before reappearance
    const adContainer = document.getElementById('ad-container');
    const closeBtn = document.getElementById('close-ad');

    function showAd() {
      // Show ad with smooth slide-in
      adContainer.style.display = 'block';
      adContainer.classList.remove('hidden');
      adContainer.setAttribute('aria-hidden', 'false');

      // Start countdown
      let timeLeft = countdownStart;
      closeBtn.textContent = `Close (${timeLeft})`;
      closeBtn.disabled = true;
      closeBtn.classList.remove('enabled');

      const t = setInterval(() => {
        timeLeft--;
        if (timeLeft > 0) {
          closeBtn.textContent = `Close (${timeLeft})`;
        } else {
          clearInterval(t);
          closeBtn.disabled = false;
          closeBtn.classList.add('enabled');
          closeBtn.textContent = 'Close ↓';
        }
      }, 1000);
    }

    // Initial ad show
    setTimeout(showAd, showDelay);

    // Close with animation and schedule reappearance
    closeBtn.addEventListener('click', () => {
      if (closeBtn.disabled) return;
      adContainer.classList.add('hidden');
      adContainer.setAttribute('aria-hidden', 'true');
      // Schedule reappearance without removing or reloading iframe
      setTimeout(showAd, reappearDelay);
    });
  })();
</script>
</body>
</html>

